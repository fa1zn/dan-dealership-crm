# ─────────────────────────────────────────────────────────────────────────────
# Dan — the full tool belt. Copy to `.env` and fill in what you have.
# Dan runs free with NONE of these set; each one arms another capability.
# `.env` is gitignored — secrets are never committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── DATA SOURCES ─────────────────────────────────────────────────────────────
# OpenStreetMap + website scraping need no keys (always on).

# OEM dealer locators (all ~20 brands → brand_confirmed, ~24K coverage).
# Endpoints are bot-protected, so route them through a non-blocked proxy IP.
# Residential/mobile proxy recommended. Format: http://user:pass@host:port
PROXY_URL=

# ── VERIFICATION ─────────────────────────────────────────────────────────────
# Google Places — independent cross-confirm (gold/platinum trust tiers).
# Google Cloud → enable Places API → create key (billing on). Restrict to Places API.
GOOGLE_PLACES_API_KEY=
# PLACES_MAX_ACCOUNTS=200   # cap per run (cost control)

# ── CRM ──────────────────────────────────────────────────────────────────────
# HubSpot (read-only pull). Private App with read scopes.
HUBSPOT_TOKEN=
# HUBSPOT_ALLOW_WRITE=0     # writing back is off by design

# ── CONTACT DATA (paid) ──────────────────────────────────────────────────────
# ZoomInfo REST API — direct dials + verified emails. Credit-safe (dry-run default).
ZOOMINFO_USERNAME=
ZOOMINFO_PASSWORD=
# ZOOMINFO_REGIONS=TX,CA,FL
# ZOOMINFO_MAX_ACCOUNTS=50
# ZOOMINFO_APPLY=1          # required to actually spend credits

# Clay — waterfall enrichment.
CLAY_TOKEN=
# CLAY_WEBHOOK_URL=

# ── SALES MOTION (autonomous call → text → edible) ───────────────────────────
# DRY-RUN by default: nothing dials, texts, or charges until SEQUENCE_APPLY=1.
SEQUENCE_APPLY=             # 1 = place real calls / texts / gifts. Unset = simulated.
SEQUENCE_ENABLED=1         # 0 = kill switch (tick no-ops)

# SAFETY: route every real send to YOURSELF first, to prove it before any rooftop.
SEQ_TEST_TO=               # e.g. +1415... — all real calls/texts go here while set
SEQ_TEST_ADDRESS=          # all real gifts go to this address while set

# Voice provider for the CALL step. Reps normally set this in the Connections UI; these
# env vars are the fallback. CALL_PROVIDER picks which one: vapi | bland | twilio.
CALL_PROVIDER=

# Vapi — composable voice AI (bring your own Vapi number + optional assistant).
VAPI_API_KEY=
VAPI_PHONE_NUMBER_ID=
# VAPI_ASSISTANT_ID=       # optional — uses a built-in Dan assistant if blank
# VAPI_VOICE=              # optional Vapi voice id

# Bland.ai — turnkey autonomous voice agent. Get a key at bland.ai.
BLAND_API_KEY=
# BLAND_VOICE=             # optional Bland voice id

# Twilio — real texts (and fallback voice TTS if no Bland key). SMS to US numbers also
# needs A2P 10DLC registration (a brand + campaign tied to your business entity; ~days).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=               # your provisioned Twilio number, e.g. +1415...

# Edible — gifting platform API (Postal / Sendoso / Reachdesk). Most autonomous path.
GIFT_API_URL=              # the provider's send endpoint
GIFT_API_KEY=

# Rails
# SEQ_GIFT_MAX_CENTS=4000      # per-gift cap
# SEQ_GIFT_BUDGET_CENTS=50000  # total program cap
# SEQ_QUIET_START=9            # local-hour guard for calls/texts (when wired)
# SEQ_QUIET_END=18

# ── MISC ─────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3210
# TARGET_TOTAL=24000        # benchmark target

# ── TODAY SCREEN ─────────────────────────────────────────────────────────────
# Action-first Today (single ranked "do this next" + why-now + one-tap snooze).
# On by default; set to 0 to revert to the legacy layout. Reversible, no data change.
# TODAY_V2=0

# ── CALENDAR (rep's own Google/Outlook, OAuth) ───────────────────────────────
# Lets Territory show the rep's real appointments + plot them on the map. No events
# are shown until connected. Register an OAuth app (Google Cloud / Azure), set the
# redirect URI to ${APP_BASE_URL}/api/calendar/callback/{google|outlook}, then:
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# MS_CALENDAR_CLIENT_ID=
# MS_CALENDAR_CLIENT_SECRET=
